		"on-click": "bash ~/.config/waybar/scripts/confirm.sh \"reboot\""
	},
	"custom/power": {
		"format": " ´Çæ ",
		"tooltip": false,
		"on-click": "bash ~/.config/waybar/scripts/confirm.sh \"shutdown now\""
	},
    "custom/power_profile": {
        "exec": "printf '%s\\n%s' \"$(powerprofilesctl get | sed 's/performance/¾░¿ó/;s/balanced/¾░Øì/;s/power-saver/¾░ØÄ/')\" \"$(powerprofilesctl get)\"",
        "tooltip": true,
        "interval": 60,
        "on-click": "powerprofilesctl set power-saver && pkill -RTMIN+8 waybar",
        "on-click-right": "powerprofilesctl set balanced && pkill -RTMIN+8 waybar",
        "on-click-middle": "powerprofilesctl set performance && pkill -RTMIN+8 waybar",
        "signal": 8
    },
